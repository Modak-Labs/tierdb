<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.modak</groupId>
        <artifactId>modak-parent</artifactId>
        <version>0.0.0</version>
    </parent>

    <artifactId>modak-worker</artifactId>
    <name>Modak :: Worker</name>
    <description>Standalone JVM entrypoint hosting the tiering + compaction loops.</description>

    <dependencies>
        <dependency>
            <groupId>io.modak</groupId>
            <artifactId>modak-tiering</artifactId>
        </dependency>
        <dependency>
            <groupId>io.modak</groupId>
            <artifactId>modak-compaction</artifactId>
        </dependency>
        <dependency>
            <groupId>io.modak</groupId>
            <artifactId>modak-lake-iceberg</artifactId>
        </dependency>
        <dependency>
            <groupId>io.modak</groupId>
            <artifactId>modak-catalog</artifactId>
        </dependency>
        <dependency>
            <groupId>io.modak</groupId>
            <artifactId>modak-cdc</artifactId>
        </dependency>

        <!-- The daemon speaks plain JDBC to any Postgres-compatible database. -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
        </dependency>

        <!-- End-to-end test: embedded Postgres + local Iceberg warehouse. -->
        <dependency>
            <groupId>io.zonky.test</groupId>
            <artifactId>embedded-postgres</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Runnable fat jar for the Docker image / bare-metal daemon. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <finalName>modak-worker</finalName>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>io.modak.worker.Main</mainClass>
                                    <manifestEntries>
                                        <!-- dnsjava (via hadoop) ships versioned classes; without this
                                             the JVM can't load its InetAddressResolver SPI. -->
                                        <Multi-Release>true</Multi-Release>
                                    </manifestEntries>
                                </transformer>
                                <!-- Merge META-INF/services (Hadoop filesystems, our LakeStoragePlugin). -->
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
